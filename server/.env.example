# Family Hub — production environment variables
# Copy this file to .env and fill in the values before running docker compose.

# --- Required ---

# OpenID Connect issuer URL (e.g. https://auth.example.com, https://accounts.google.com)
OIDC_ISSUER=https://auth.example.com

# OAuth2 client ID registered with your OIDC provider
OIDC_CLIENT_ID=family-hub

# OAuth2 callback URL — must match the redirect URI registered with your provider
OIDC_REDIRECT_URL=https://hub.example.com/auth/callback

# Random secret used to sign session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-me-with-a-random-secret

# --- Recommended ---

# Public base URL of the app (used for absolute links)
BASE_URL=https://hub.example.com

# 16 or 32 ASCII chars to encrypt session cookies (generate with: openssl rand -hex 16)
# If unset, cookies are signed but not encrypted.
SESSION_ENCRYPTION_KEY=

# --- Optional ---

# Path to the SQLite database file (default: ./data/family-hub.db)
DATABASE_PATH=./data/family-hub.db

# Server port (default: 8080)
PORT=8080

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Set to true to bypass OIDC and auto-login as a dev admin — NEVER use in production
DEV_MODE=false
